# ===================================================================
# Secret Configuration Template
# ===================================================================
# Copy this file to `secret.yaml` and fill in your credentials:
#   cp secret.yaml.example secret.yaml
#
# All values can also be provided via environment variables (uppercase):
#   export ZIZI_EMAIL="your@email.com"
# ===================================================================

# --- ZIZIZAIZAI (AI Morning Reports & Topics) ---
# Register at https://quant.zizizaizai.com
zizi_email: "your@email.com"
zizi_password: "your_password"

# --- ZZSHARE (Custom SDK for sentiment & K-line data) ---
zzshare_token: "your_zzshare_token"

# --- DeepSeek (YMOS Risk Audit) ---
# Get your API key at https://platform.deepseek.com
deepseek_api_key: "your_deepseek_api_key"

# --- iWencai (Optional: NL search API) ---
# Leave empty to use the free web scraping fallback.
iwencai_api_key: ""
iwencai_base_url: "https://openapi.iwencai.com"
